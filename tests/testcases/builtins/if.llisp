(displayln (if #t "ok" "wrong")) ; expect: ok
(displayln (if #f "wrong" "ok")) ; expect: ok

; only false itself is falsy
(displayln (if () "ok" "wrong")) ; expect: ok
(displayln (if 0 "ok" "wrong")) ; expect: ok
(displayln (if "" "ok" "wrong")) ; expect: ok

; (if #f anything) with no else-part returns #f
(displayln (if #f "wrong")) ; expect: #f
