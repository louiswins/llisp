(display (number? 12345)) (newline) ; expect: #t
(display (number? +12345)) (newline) ; expect: #t
(display (number? -12345)) (newline) ; expect: #t
(display (number? 12345.)) (newline) ; expect: #t
(display (number? .12345)) (newline) ; expect: #t
(display (number? 12345.6)) (newline) ; expect: #t
(display (number? 12345e6)) (newline) ; expect: #t
(display (number? 12345.6e7)) (newline) ; expect: #t
(display (number? 12345.6e+7)) (newline) ; expect: #t
(display (number? 12345.6e-7)) (newline) ; expect: #t
