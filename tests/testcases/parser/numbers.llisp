; expect: #t
; forbid: #f
(display (number? 12345)) (newline)
(display (number? +12345)) (newline)
(display (number? -12345)) (newline)
(display (number? 12345.)) (newline)
(display (number? .12345)) (newline)
(display (number? 12345.6)) (newline)
(display (number? 12345e6)) (newline)
(display (number? 12345.6e7)) (newline)
(display (number? 12345.6e+7)) (newline)
(display (number? 12345.6e-7)) (newline)
