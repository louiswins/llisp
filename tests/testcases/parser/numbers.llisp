(displayln (number? 12345)) ; expect: #t
(displayln (number? +12345)) ; expect: #t
(displayln (number? -12345)) ; expect: #t
(displayln (number? 12345.)) ; expect: #t
(displayln (number? .12345)) ; expect: #t
(displayln (number? 12345.6)) ; expect: #t
(displayln (number? 12345e6)) ; expect: #t
(displayln (number? 12345.6e7)) ; expect: #t
(displayln (number? 12345.6e+7)) ; expect: #t
(displayln (number? 12345.6e-7)) ; expect: #t
