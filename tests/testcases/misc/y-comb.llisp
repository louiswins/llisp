(define (Y f)
  ((lambda (x) (x x))
   (lambda (x) (f (lambda v (apply (x x) v))))))

(define factorial-with-Y (Y (lambda (rec)
  (lambda (n)
    (if (<= n 1)
        1
        (* n (rec (- n 1))))))))

(define (Y! f-maker)
  ((lambda (f)
     (set! f (f-maker (lambda v (apply f v))))
     f)
   'UNDEFINED))

(define factorial-with-Y! (Y! (lambda (rec)
  (lambda (n)
    (if (<= n 1)
        1
        (* n (rec (- n 1))))))))

(displayln (map factorial-with-Y (range 10))) ; expect: (1 1 2 6 24 120 720 5040 40320 362880)

(displayln (map factorial-with-Y! (range 10))) ; expect: (1 1 2 6 24 120 720 5040 40320 362880)
