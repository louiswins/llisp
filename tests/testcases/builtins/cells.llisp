(displayln (cons 1 nil)) ; expect: (1)
(displayln (car (cons 2 nil))) ; expect: 2
(displayln (cdr (cons 3 nil))) ; expect: ()
(displayln (car '(4))) ; expect: 4
(displayln (cdr '(5))) ; expect: ()

(displayln (car (cons 6 7))) ; expect: 6
(displayln (cdr (cons 8 9))) ; expect: 9
(displayln (cons 10 11)) ; expect: (10 . 11)

(displayln (pair? '(12 . 13))) ; expect: #t
(displayln (pair? '(14 15))) ; expect: #t
