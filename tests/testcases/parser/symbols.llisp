(displayln (symbol? 'a)) ; expect: #t
(displayln (symbol? 'symbol?)) ; expect: #t
(displayln (symbol? 'with-a-dash)) ; expect: #t
(displayln (symbol? 'number123)) ; expect: #t
(displayln (symbol? '890-can-start-with-number)) ; expect: #t
(displayln (symbol? '1.2.3)) ; expect: #t
(displayln (symbol? '234e)) ; expect: #t

