(display (symbol? 'a)) (newline) ; expect: #t
(display (symbol? 'symbol?)) (newline) ; expect: #t
(display (symbol? 'with-a-dash)) (newline) ; expect: #t
(display (symbol? 'number123)) (newline) ; expect: #t
(display (symbol? '890-can-start-with-number)) (newline) ; expect: #t
(display (symbol? '1.2.3)) (newline) ; expect: #t
(display (symbol? '234e)) (newline) ; expect: #t

